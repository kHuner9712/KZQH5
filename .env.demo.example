# 本地前端预览环境配置示例
# 用途：无需连接 Supabase 即可预览前台 H5 视觉与交互
# 使用方式：复制为 .env.local 后运行 npm run dev
#   cp .env.demo.example .env.local
#
# 注意：此模式下前台使用 mock 数据（lib/mock-data.ts），不请求 Supabase，
#       后台管理 / 询盘 API 的真实写入功能不可用。

# Demo / Mock Preview 模式开关
NEXT_PUBLIC_DEMO_MODE=true

# 站点域名（用于 SEO / 绝对 URL）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 以下 Supabase 配置在 Demo 模式下不会被前台使用，可留空占位
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
