{
  "name": "kzq-h5",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:demo": "cross-env NEXT_PUBLIC_DEMO_MODE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:demo": "cross-env NEXT_PUBLIC_DEMO_MODE=true playwright test tests/e2e/demo-public.spec.ts tests/e2e/demo-documents.spec.ts",
    "test:e2e:staging": "playwright test tests/e2e/staging-public.spec.ts tests/e2e/staging-admin.spec.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:database": "node scripts/verify-database.mjs",
    "test:database:staging": "node scripts/verify-staging-database.mjs",
    "database:init:staging": "node scripts/init-staging-database.mjs",
    "catalog:import": "node scripts/import-catalog-assets.mjs",
    "catalog:import:dry": "node scripts/import-catalog-assets.mjs",
    "catalog:import:apply": "node scripts/import-catalog-assets.mjs --apply",
    "catalog:download": "node scripts/download-catalog-assets.mjs",
    "catalog:download:apply": "node scripts/download-catalog-assets.mjs --apply",
    "check:deployed": "node scripts/check-deployed-site.mjs",
    "check:release-readiness": "node scripts/check-release-readiness.mjs",
    "check:release-readiness:staging": "node scripts/check-release-readiness.mjs --mode=staging",
    "check": "npm run typecheck && npm run lint && npm run test:unit && npm run build:demo"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "15.5.21",
    "pdfjs-dist": "^4.8.69",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.16.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.21",
    "jsdom": "^29.1.1",
    "mupdf": "^1.28.0",
    "postcss": "8.5.16",
    "prettier": "3.6.2",
    "supabase": "^2.109.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.16",
    "sharp": "^0.35.0"
  }
}
