# Supabase 配置（在 Supabase 项目 Settings > API 中获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 仅服务端使用，绝不能暴露到客户端组件 / NEXT_PUBLIC_ 前缀
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 站点域名（用于 SEO / sitemap / 绝对 URL）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 中英文页面共用该站点地址；不要在末尾添加 /en。
# canonical、hreflang、Open Graph 与 sitemap 会自动生成中文无前缀和英文 /en URL。

# Demo / Mock Preview 模式（true 时前台使用 mock 数据，不请求 Supabase）
# 生产 / 正常开发环境请保持 false；如需纯前端预览，请参考 .env.demo.example
NEXT_PUBLIC_DEMO_MODE=false

# 搜索引擎索引开关（严格匹配 "true" 才允许索引；其他值或未设置一律 noindex）
# 默认关闭。EdgeOne 正式域名验收通过后才设置为 true。
# Vercel Preview 与当前 Vercel Production 一律保持 false，避免占位内容被收录。
NEXT_PUBLIC_SITE_INDEXING_ENABLED=false

# 可选：仅 Staging 的受保护依赖诊断。两个变量必须同时通过部署平台 Secret 配置。
# 未启用时 /api/staging/diagnostics 返回 404；不要把 Token 写入浏览器或日志。
STAGING_DIAGNOSTICS_ENABLED=false
STAGING_DIAGNOSTICS_TOKEN=

# 以下仅用于本机/手动 GitHub staging 验证，不是应用运行所需变量。
# 写入测试还必须显式设置对应 ALLOW_WRITES=true；默认只读。
# KZQ_STAGING_CONFIRMATION=KZQ-STAGING-ONLY
# SMOKE_TEST_ALLOW_WRITES=false
# STAGING_E2E_ALLOW_WRITES=false
# DATABASE_STAGING_URL=
# KZQ_STAGING_PROJECT_REF=

# 产品搜索 RPC 与匿名询盘清单不需要新增环境变量。
# 询盘清单仅保存在浏览器 localStorage，不保存联系人信息。
# 采购资料、证书查看器与应用案例功能也不需要新增环境变量；文件继续使用 public-assets。

# 可选：新询盘通知（全部仅服务端使用；未配置时正常提交）
INQUIRY_WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-me
RESEND_API_KEY=re_replace_me
INQUIRY_NOTIFICATION_FROM=KZQ Website <inquiries@example.com>
INQUIRY_NOTIFICATION_TO=sales@example.com

# 可选：微信公众号网页 JS-SDK（仅服务端使用，绝不能添加 NEXT_PUBLIC_ 前缀）
# 两项同时配置后，仅微信内置浏览器会尝试启用；未配置时普通网页分享照常工作。
WECHAT_APP_ID=
WECHAT_APP_SECRET=
