# Supabase 配置（在 Supabase 项目 Settings > API 中获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 仅服务端使用，绝不能暴露到客户端组件 / NEXT_PUBLIC_ 前缀
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 站点域名（用于 SEO / sitemap / 绝对 URL）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Demo / Mock Preview 模式（true 时前台使用 mock 数据，不请求 Supabase）
# 生产 / 正常开发环境请保持 false；如需纯前端预览，请参考 .env.demo.example
NEXT_PUBLIC_DEMO_MODE=false

